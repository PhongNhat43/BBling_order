rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /orders/{orderId} {
      allow read, write: if true;
      match /messages/{msgId} {
        allow read, write: if true;
      }
    }
    match /menu/{document=**} {
      allow read, write: if true;
    }
    match /test/{document=**} {
      allow read, write: if true;
    }
    match /guestChats/{document=**} {
      allow read, write: if true;
    }
    // Store-wide settings — payment_config is publicly readable (needed by payment.html),
    // telegram_config requires auth (contains bot token)
    match /settings/{docId} {
      allow read: if docId == 'payment_config' || request.auth != null;
      allow write: if request.auth != null;
    }
    // Admin user management — authenticated users can read (for login check),
    // write is restricted to authenticated users (dashboard auth guard handles role enforcement)
    match /admin_users/{email} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }
  }
}
